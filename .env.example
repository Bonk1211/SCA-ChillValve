# ChillValve environment variables (copy to .env and fill in)

# --- Optional: LLM event narration (backend/explainer.py) ---
# Get a key at https://aistudio.google.com/app/apikey
# Without a key, the explainer falls back to deterministic templates.
GEMINI_API_KEY=

# --- Optional: backend tuning ---
# Tick cadence in seconds. Default 0.05 = 20 Hz wall-clock (1 sim-second / 50 ms).
# Lower = faster demo playback; higher = closer to real-time.
# CHILLVALVE_TICK_PERIOD_S=0.05

# Path to the SQLite database file. Default data/chillvalve.db.
# CHILLVALVE_DB_PATH=data/chillvalve.db
