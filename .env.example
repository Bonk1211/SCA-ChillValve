# ChillValve environment variables (copy to .env and fill in)

# --- Optional: LLM (backend/explainer.py + backend/debate.py) ---
# Provider: DeepSeek via the OpenAI-compatible API at https://api.deepseek.com.
# Get a key at https://platform.deepseek.com/api_keys
# Model: deepseek-v4-flash (configured in backend/{explainer,debate}.py).
# Without a key:
#   - leader-change explainer falls back to deterministic templates
#   - multi-agent debate is disabled; controller uses deterministic Layer 3 allocation
DEEPSEEK_API_KEY=

# --- Optional: backend tuning ---
# Tick cadence in seconds. Default 0.05 = 20 Hz wall-clock (1 sim-second / 50 ms).
# Lower = faster demo playback; higher = closer to real-time.
# CHILLVALVE_TICK_PERIOD_S=0.05

# Path to the SQLite database file. Default data/chillvalve.db.
# CHILLVALVE_DB_PATH=data/chillvalve.db
